<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_margin="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:id="@+id/layout_item_favorite">


        <ImageView
            android:id="@+id/iv_favorite_cover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/backgrounds/scenic"
            tools:ignore="ContentDescription" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ib_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/selector_favorite"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="16dp"
            android:background="@color/white"
            android:scaleType="centerInside"
            app:shapeAppearanceOverlay="@style/RoundedSquare"
            app:tint="@color/pink"
            app:layout_constraintStart_toStartOf="@id/iv_favorite_cover"
            app:layout_constraintBottom_toBottomOf="@id/iv_favorite_cover"
            tools:ignore="ContentDescription,VisualLintBounds" />

        <TextView
            android:id="@+id/tv_favorite_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:background="@drawable/bg_category_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toTopOf="@+id/tv_favorite_name"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="TextContrastCheck"
            tools:text="Technology" />

        <TextView
            android:id="@+id/tv_favorite_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:paddingVertical="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?android:attr/colorForeground"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_favorite_cover"
            tools:text="Event Name Example" />

        <TextView
            android:id="@+id/tv_favorite_city_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:ellipsize="end"
            android:maxLines="2"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintEnd_toStartOf="@id/tv_favorite_quota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_favorite_name"
            tools:text="Jakarta • 20 Oct 2023, 10:00" />

        <TextView
            android:id="@+id/tv_favorite_quota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            android:textSize="11sp"
            android:textColor="@color/black"
            app:layout_constraintHorizontal_weight="0.3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_favorite_city_time"
            app:layout_constraintTop_toTopOf="@id/tv_favorite_city_time"
            app:layout_constraintBottom_toBottomOf="@id/tv_favorite_city_time"
            tools:text="Quota: 50 left"
            tools:ignore="SmallSp" />

        <ImageView
            android:id="@+id/ib_favorite_expand"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_margin="4dp"
            android:src="@drawable/selector_dropdown"
            android:background="?attr/selectableItemBackground"
            android:scaleType="fitEnd"
            app:layout_constraintTop_toBottomOf="@id/tv_favorite_city_time"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/pink"
            tools:ignore="ContentDescription,VisualLintBounds"/>

        <TextView
            android:id="@+id/tv_favorite_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="4dp"
            android:layout_marginHorizontal="12dp"
            android:textColor="@color/black"
            android:fontFamily="serif"
            android:textSize="14sp"
            android:ellipsize="end"
            android:maxLines="6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ib_favorite_expand"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="@tools:sample/lorem/random" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>